INTERN_API_BASE=https://chat.intern-ai.org.cn/api/v1
INTERN_API_KEY=your-intern-api-key-here
SCIVERSE_API_TOKEN=sv-your-sciverse-token-here
MINERU_API_TOKEN=your-mineru-token-here
MINERU_ENABLED=true
MINERU_TIMEOUT=600
MINERU_BATCH_SIZE=1
MINERU_FAST=true

# Optional Skill system. Built-in skills work without configs/skills.toml.
SKILLS_ENABLED=true
SKILLS_CONFIG=configs/skills.toml
# Optional override. By default, skill trace is written inside the current output/runs/... directory.
# SKILLS_TRACE_PATH=/absolute/path/to/skill_trace.json

# Optional image generation.
IMAGE_GENERATION_ENABLED=false
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
